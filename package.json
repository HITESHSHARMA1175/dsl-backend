{
  "name": "dsl-clinic-backend",
  "version": "1.0.0",
  "description": "DSL Clinic (Diamond Skin London) Express.js + TypeScript REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "node scripts/build.js",
    "start": "node dist/server.js",
    "start:ts": "ts-node --transpile-only src/server.ts",
    "start:compiled": "node dist/server.js",
    "test": "jest --runInBand",
    "postinstall": "prisma generate && node scripts/build.js",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "export:openapi": "ts-node scripts/export-openapi.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "prisma": "^5.22.0",
    "stripe": "^17.5.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.2.5"
  }
}

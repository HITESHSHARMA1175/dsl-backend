  discounted_price           Float    @default(0.00)
  session2                   Int?
  price2                     Float    @default(0.00)
  discounted_price2          Float    @default(0.00)
  session3                   Int?
  price3                     Float    @default(0.00)
  discounted_price3          Float    @default(0.00)
  session4                   Int?

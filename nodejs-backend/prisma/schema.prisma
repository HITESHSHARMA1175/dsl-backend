generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  emp_id                 String?               @db.VarChar(255)
  menu_permission        String?               @db.VarChar(400)
  emp_type               String?               @db.VarChar(255)
  reporting_boss         Int?
  is_show_contact        users_is_show_contact @default(dbgenerated("'0'"))
  designation            Int?
  first_name             String                @db.VarChar(255)
  last_name              String?               @db.VarChar(100)
  email                  String?               @unique(map: "users_email_unique") @db.VarChar(255)
  mobile_no              String?               @db.VarChar(20)
  gender                 String?               @db.VarChar(50)
  dob                    DateTime?             @db.Date
  shop_name              String?               @db.VarChar(255)
  shop_gst               String?               @db.VarChar(255)
  shop_pan               String?               @db.VarChar(255)
  shop_business_no       String?               @db.VarChar(255)
  address                String?               @db.Text
  country                String?               @db.VarChar(20)
  state                  String?               @db.VarChar(20)
  city                   String?               @db.VarChar(20)
  pincode                Int?
  date_of_joining        DateTime?             @db.Date
  monthly_target         Int?                  @default(0)
  monthly_meeting_target Int?                  @default(0)
  daily_followup_target  Int?                  @default(0)
  password               String?               @db.VarChar(500)
  password_copy          String?               @db.VarChar(255)
  type                   String?               @db.VarChar(255)
  email_verified_at      DateTime?             @db.Timestamp(0)
  account_name           String?               @db.VarChar(255)
  account_no             String?               @db.VarChar(255)
  bank_name              String?               @db.VarChar(255)
  ifcs                   String?               @db.VarChar(255)
  bank_address           String?               @db.VarChar(255)
  profile                String?               @db.VarChar(255)
  profile_aadhar         String?               @db.VarChar(255)
  upload_aadhaar         String?               @db.VarChar(255)
  aadhar_number          String?               @db.VarChar(255)
  upload_pan             String?               @db.VarChar(255)
  pan_number             String?               @db.VarChar(255)
  upload_resume          String?               @db.VarChar(255)
  upload_cancel_cheque   String?               @db.VarChar(255)
  location_address       String?               @db.VarChar(255)
  location_lat           String?               @db.VarChar(255)
  location_lng           String?               @db.VarChar(255)
  location_date          String?               @db.VarChar(255)
  location_time          String?               @db.VarChar(255)
  is_admin               Int                   @default(0)
  is_sub_admin           users_is_sub_admin
  is_seller              users_is_seller
  is_kyc                 users_is_kyc
  status                 Int                   @default(1) @db.TinyInt
  remember_token         String?               @db.VarChar(100)
  otp                    Int                   @default(1234)
  business_name          String?               @db.VarChar(255)
  business_type          String?               @db.VarChar(255)
  business_category      String?               @db.VarChar(255)
  business_email         String?               @db.VarChar(255)
  created_at             DateTime?             @default(now()) @db.Timestamp(0)
  updated_at             DateTime?             @default(now()) @updatedAt @db.Timestamp(0)

  @@map("users")
}

model Customer {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  first_name     String?   @db.VarChar(255)
  last_name      String?   @db.VarChar(255)
  mobile         String?   @db.VarChar(255)
  email          String?   @db.VarChar(255)
  dob            String?   @db.VarChar(255)
  gender         String?   @db.VarChar(255)
  status         Int       @default(1) @db.TinyInt
  otp            Int       @default(1234)
  password       String    @default("$2y$10$uk4SBhAZKc/SwryaU8uKyeWeYfZxED5YcZXJYitCnBlAP4Mep9JpS") @db.VarChar(255)
  remember_token String?   @db.VarChar(100)
  device_token   String?   @db.Text
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@map("customers")
}

